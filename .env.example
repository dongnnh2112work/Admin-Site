# Copy sang .env.local và điền giá trị từ Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=brand-assets

# Chỉ local: vào admin bằng nút trên /login + cookie (không cần Supabase Auth). Không bật trên production.
NEXT_PUBLIC_DEV_AUTH_BYPASS=false
